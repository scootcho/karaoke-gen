# Environment variables for local development and testing
# Copy this file to .env.local and fill in your values

# =============================================================================
# E2E Testing - Email (for beta enrollment flow)
# =============================================================================

# testmail.app credentials for email testing
# Get these from https://testmail.app dashboard
TESTMAIL_API_KEY=your-api-key-here
TESTMAIL_NAMESPACE=your-namespace-here

# =============================================================================
# E2E Testing - Authentication (optional)
# =============================================================================

# Skip email enrollment by providing an existing access token
# Useful for faster local testing when you already have credits
# KARAOKE_ACCESS_TOKEN=your-token-here
