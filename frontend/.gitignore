playwright-report-prod/
playwright-report-demo/

# Demo video output and raw recordings (large files, not for git)
demo-output/
docs/images/e2e-happy-path/video/

# Local debug scripts (may contain tokens - never commit)
# Use this pattern for ad-hoc testing: test-*.local.{js,cjs,mjs,ts}
test-*.local.*
debug-*.local.*

# Search result fixtures (large raw data, regenerate with fetch-search-fixtures.mjs)
# The index.json is tracked for reference; individual result files are gitignored
e2e/fixtures/data/search-results/*.json
!e2e/fixtures/data/search-results/index.json

# Chrome profile for interactive fixture review (auto-created by playwright.review.config.ts)
.review-profile/

# Translation snapshot for incremental delta mode
messages/.en-snapshot.json
